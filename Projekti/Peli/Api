@app.route('/add_reward/<int:peli_id>', methods=['POST'])
def add_reward(peli_id):
    cursor = Peli.Yhdiste.cursor()
    # Adds 500 to the current alcohol level
    sql = "UPDATE game SET alcohol = alcohol + 500 WHERE id = %s"
    cursor.execute(sql, (peli_id,))
    Peli.Yhdiste.commit()
    cursor.close()
    return jsonify({"status": "Reward added"})

# aloitaa pelin  ja katsoo peljaana tavarat

@app.route('/start_game', methods=['POST'])
def start_game():
    json_data = request.json
    pelaaja_nimi = json_data.get('name')

    cursor = Peli.Yhdiste.cursor(dictionary=True)

    check_sql = "SELECT id FROM game WHERE screen_name = %s ORDER BY id DESC LIMIT 1"
    cursor.execute(check_sql, (pelaaja_nimi,))
    existing_player = cursor.fetchone()

    if existing_player:
        peli_id = existing_player['id']
        print(f"Ladataan vanha peli: {pelaaja_nimi} (ID: {peli_id})")
    else:
        insert_sql = "INSERT INTO game (screen_name, location, alcohol) VALUES (%s, 'EFHK', 1000)"
        cursor.execute(insert_sql, (pelaaja_nimi,))
        Peli.Yhdiste.commit()
        peli_id = cursor.lastrowid
        print(f"Luotiin uusi peli: {pelaaja_nimi} (ID: {peli_id})")

    cursor.close()
    return jsonify({"peli_id": peli_id, "name": pelaaja_nimi})


