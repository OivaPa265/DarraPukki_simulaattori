# hakee pelaajan stauksen eli tämän tavarat lokaatioin ja liikumis matkan jne
@app.route('/status/<int:peli_id>', methods=['GET'])
def hae_status(peli_id):
    cursor = Peli.Yhdiste.cursor(dictionary=True)
    # Hakee viimeiset tavarat ja kentän
    sql = "SELECT screen_name, location, alcohol FROM game WHERE id = %s"
    cursor.execute(sql, (peli_id,))
    result = cursor.fetchone()
    cursor.close()

    if result:
        return jsonify({
            "status": "success",
            "name": result['screen_name'],
            "location": result['location'],
            "alcohol": result['alcohol']
        })
    return jsonify({"status": "error", "message": "Peliä ei löytynyt"}), 404

